.property-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
  background: #f5f5f5;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-type-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(232, 64, 64, 0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.card-status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-green { background: rgba(82,196,26,0.9); color: #fff; }
.tag-gray  { background: rgba(0,0,0,0.45); color: #fff; }
.tag-blue  { background: rgba(24,144,255,0.9); color: #fff; }

.card-body {
  padding: 24rpx 28rpx 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  font-size: 26rpx;
  color: #888;
  margin-top: 12rpx;
}

.dot {
  margin: 0 8rpx;
  color: #ccc;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.price-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #E84040;
}

.views-text {
  font-size: 24rpx;
  color: #bbb;
}
