.property-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 20rpx rgba(2,132,199,0.10);
  margin-bottom: 24rpx;
}

.property-card:active {
  opacity: 0.92;
  transform: scale(0.99);
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
  background: #f5f5f5;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-type-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(2, 132, 199, 0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.card-status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-green { background: rgba(82,196,26,0.9); color: #fff; }
.tag-gray  { background: rgba(0,0,0,0.45); color: #fff; }
.tag-blue  { background: rgba(24,144,255,0.9); color: #fff; }

.card-video-badge {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.card-body {
  padding: 28rpx 28rpx 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  font-size: 26rpx;
  color: #8a9ab0;
  margin-top: 10rpx;
  line-height: 1.5;
}

.dot {
  margin: 0 8rpx;
  color: #d4dde8;
}

.card-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f7fa;
}

.price-num {
  font-size: 42rpx;
  font-weight: 800;
  color: #0284C7;
  letter-spacing: -0.5rpx;
}

.views-text {
  font-size: 24rpx;
  color: #c0cad6;
}

/* compact 双列模式 */
.property-card-compact {
  margin-bottom: 0;
}

.card-image-compact {
  height: 220rpx;
}

.card-body-compact {
  padding: 18rpx 18rpx 16rpx;
}

.card-title-compact {
  font-size: 26rpx;
  font-weight: 600;
}

.card-meta-compact {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.card-bottom-compact {
  margin-top: 12rpx;
  padding-top: 10rpx;
}

.price-compact {
  font-size: 34rpx;
}
