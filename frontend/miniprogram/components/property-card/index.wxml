<wxs module="fmt" src="../../utils/format.wxs" />

<view class="property-card" bindtap="onTap">
  <view class="card-image-wrap">
    <image
      class="card-image"
      src="{{coverImage}}"
      mode="aspectFill"
      lazy-load
    />
    <view class="card-type-tag">{{property.property_type}}</view>
    <view wx:if="{{showStatus}}" class="card-status-tag {{fmt.statusClass(property.status)}}">{{fmt.statusLabel(property.status)}}</view>
  </view>

  <view class="card-body">
    <view class="card-title">{{property.title}}</view>
    <view class="card-meta">
      <text>{{fmt.formatLayout(property.bedrooms, property.living_rooms, property.bathrooms)}}</text>
      <text class="dot">·</text>
      <text>{{fmt.formatArea(property.area)}}</text>
      <text class="dot">·</text>
      <text>{{property.district}}</text>
    </view>
    <view class="card-bottom">
      <view class="card-price">
        <text class="price-num">{{fmt.formatPrice(property.total_price, property.property_type === '租房' ? 'rent' : 'sale')}}</text>
      </view>
      <view class="card-views">
        <text class="views-text">{{property.view_count}}次浏览</text>
      </view>
    </view>
  </view>
</view>
