.drawer-wrap {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
}

.drawer-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0,0,0,0.45);
}

.drawer-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.drawer-title {
  padding: 32rpx 32rpx 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.drawer-body {
  flex: 1;
  overflow: hidden;
  padding: 0 32rpx;
}

.filter-section {
  padding: 28rpx 0 0;
}

.section-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #555;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.tag-active {
  color: #E84040;
  background: #fff0f0;
  border-color: #E84040;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.range-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #222;
}

.range-sep {
  font-size: 26rpx;
  color: #ccc;
}

.drawer-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  border-top: 1rpx solid #f0f0f0;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-reset {
  background: #f5f5f5;
  color: #555;
}

.btn-confirm {
  background: #E84040;
  color: #fff;
}
