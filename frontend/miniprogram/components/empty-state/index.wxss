.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon-text {
  font-size: 120rpx;
  opacity: 0.4;
  line-height: 1;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 24rpx;
}

.empty-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  background: #0284C7;
  color: #fff;
  font-size: 28rpx;
}
