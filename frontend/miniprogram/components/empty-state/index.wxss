.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 24rpx;
}

.empty-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  background: #E84040;
  color: #fff;
  font-size: 28rpx;
}
