.agent-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.agent-info {
  display: flex;
  align-items: flex-start;
}

.agent-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.agent-detail {
  flex: 1;
  margin-left: 24rpx;
}

.agent-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.agent-title {
  font-size: 24rpx;
  color: #E84040;
  margin-top: 6rpx;
}

.agent-bio {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.agent-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  gap: 8rpx;
}

.btn-call {
  background: #E84040;
  color: #fff;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}
