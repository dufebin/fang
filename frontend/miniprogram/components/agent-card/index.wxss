.agent-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.agent-info {
  display: flex;
  align-items: flex-start;
}

.agent-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.agent-detail {
  flex: 1;
  margin-left: 24rpx;
}

.agent-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.agent-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.agent-badge {
  font-size: 20rpx;
  color: #0284C7;
  background: #e0f2fe;
  border-radius: 16rpx;
  padding: 4rpx 12rpx;
}

.agent-title {
  font-size: 24rpx;
  color: #0284C7;
  margin-top: 6rpx;
}

.agent-bio {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.agent-phone-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.agent-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  gap: 8rpx;
}

.btn-light {
  background: #f1f5f9;
  color: #0f172a;
}

.btn-call {
  background: #0284C7;
  color: #fff;
}

.action-icon-text {
  font-size: 30rpx;
}
