/* Page */
.page {
  background: #f4f5f7;
  min-height: 100vh;
  padding: 20rpx 24rpx 160rpx;
}

/* Card */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
  margin-bottom: 8rpx;
}

.header-bar {
  width: 6rpx;
  height: 32rpx;
  background: #E84040;
  border-radius: 3rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
}

.card-hint {
  font-size: 22rpx;
  color: #aaa;
}

.req { color: #E84040; }

/* Field rows */
.field-row {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #f2f2f2;
}

.field-row.tag-field {
  align-items: flex-start;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  min-height: auto;
}

.field-row.no-border { border-bottom: none; }

.field-label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #222;
  background: transparent;
}

.field-right { text-align: right; }

/* Unit suffix */
.unit-wrap {
  flex: 1;
  display: flex;
  align-items: center;
}

.unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* Location row (region picker + locate button) */
.location-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.region-picker { flex: 1; }

.region-display {
  font-size: 28rpx;
  color: #222;
  text-align: right;
}

.region-display.placeholder { color: #bbb; }

.locate-btn {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  background: #fff0f0;
  border: 1rpx solid #E84040;
  color: #E84040;
  font-size: 24rpx;
  white-space: nowrap;
}

.locate-btn.locating {
  background: #f5f5f5;
  border-color: #ccc;
  color: #999;
}

/* Floor row */
.floor-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.floor-input {
  width: 120rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #222;
}

.floor-sep { font-size: 28rpx; color: #999; }

/* Room stepper block */
.rooms-card {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #fafafa;
  margin: 0 28rpx 20rpx;
  border-radius: 12rpx;
}

.room-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.room-sep {
  width: 1rpx;
  height: 60rpx;
  background: #ebebeb;
}

.room-label { font-size: 24rpx; color: #888; }

.stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.step-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  line-height: 1;
}

.step-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  min-width: 40rpx;
  text-align: center;
}

/* Tag pills */
.tag-group {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  padding: 8rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 1rpx solid transparent;
}

.pill-active {
  color: #E84040;
  background: #fff0f0;
  border-color: #E84040;
}

/* Description */
.desc-area {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.desc-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
  padding: 0 28rpx 20rpx;
}

/* Status pills */
.status-row {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx 28rpx;
  flex-wrap: wrap;
}

.status-pill {
  padding: 12rpx 36rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: #888;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.s-available.s-active { color: #16a34a; background: #f0fdf4; border-color: #16a34a; }
.s-sold.s-active      { color: #555;    background: #f5f5f5; border-color: #999; }
.s-rented.s-active    { color: #2563eb; background: #eff6ff; border-color: #2563eb; }
.s-offline.s-active   { color: #dc2626; background: #fff5f5; border-color: #dc2626; }

/* Image grid — 3 per row */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 28rpx 28rpx;
}

.img-cell {
  position: relative;
  width: 196rpx;
  height: 196rpx;
}

.img-thumb {
  width: 196rpx;
  height: 196rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
}

.cover-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: rgba(232,64,64,0.85);
  border-radius: 0 0 10rpx 10rpx;
}

.img-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.set-cover-btn {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: rgba(0,0,0,0.45);
  border-radius: 0 0 10rpx 10rpx;
}

/* 视频区 */
.video-section {
  padding: 16rpx 28rpx 28rpx;
}

.video-add {
  height: 180rpx;
  border-radius: 10rpx;
  border: 2rpx dashed #d9d9d9;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.video-add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.video-add-label {
  font-size: 24rpx;
  color: #bbb;
}

.video-wrap {
  position: relative;
}

.video-preview {
  width: 100%;
  height: 360rpx;
  border-radius: 10rpx;
  background: #000;
}

.video-del {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #E84040;
  padding: 12rpx 0;
}

.img-add {
  width: 196rpx;
  height: 196rpx;
  border-radius: 10rpx;
  border: 2rpx dashed #d9d9d9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fafafa;
}

.add-plus { font-size: 56rpx; color: #ccc; line-height: 1; font-weight: 300; }
.add-label { font-size: 22rpx; color: #bbb; }

/* Fixed bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
}

.submit-btn {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: #E84040;
  color: #fff;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
