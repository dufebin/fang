<view class="page">

  <!-- 房源图片 -->
  <view class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">房源图片</text>
      <text class="card-hint">最多9张，首张为封面</text>
    </view>
    <view class="img-grid">
      <view class="img-cell" wx:for="{{images}}" wx:key="index">
        <image class="img-thumb" src="{{item.url || item}}" mode="aspectFill" />
        <view wx:if="{{index === 0}}" class="cover-tag">封面</view>
        <view wx:else class="set-cover-btn" catchtap="onSetCover" data-index="{{index}}">设封面</view>
        <view class="img-del" catchtap="onDelImage" data-index="{{index}}">×</view>
      </view>
      <view wx:if="{{images.length < 9}}" class="img-add" bindtap="onAddImage">
        <text class="add-plus">+</text>
        <text class="add-label">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 房源视频 -->
  <view class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">房源视频</text>
      <text class="card-hint">最长2分钟</text>
    </view>
    <view class="video-section">
      <view wx:if="{{videoUrl}}" class="video-wrap">
        <video class="video-preview" src="{{videoUrl}}" controls show-center-play-btn object-fit="contain" />
        <view class="video-del" catchtap="onDelVideo">删除视频</view>
      </view>
      <view wx:else class="video-add" bindtap="onAddVideo">
        <text class="video-add-icon">▶</text>
        <text class="video-add-label">添加视频</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">基本信息</text>
    </view>

    <view class="field-row">
      <text class="field-label">房源标题<text class="req"> *</text></text>
      <input class="field-input" placeholder="如：朝阳区三居室精装修" value="{{form.title}}" bindinput="onInput" data-field="title" maxlength="60" />
    </view>

    <view class="field-row tag-field">
      <text class="field-label">房源类型</text>
      <view class="tag-group">
        <view wx:for="{{propertyTypes}}" wx:key="value" class="pill {{form.property_type === item.value ? 'pill-active' : ''}}" data-val="{{item.value}}" bindtap="onTypeSelect">{{item.label}}</view>
      </view>
    </view>

    <view class="field-row no-border">
      <text class="field-label">省市区<text class="req"> *</text></text>
      <view class="location-row">
        <picker mode="region" value="{{regionValue}}" bindchange="onRegionChange" class="region-picker">
          <view class="region-display {{form.city ? '' : 'placeholder'}}">
            {{form.city ? (form.province + ' ' + form.city + ' ' + form.district) : '请选择省市区'}}
          </view>
        </picker>
        <view class="locate-btn {{locating ? 'locating' : ''}}" bindtap="onAutoLocation">
          <text>{{locating ? '定位中' : '定位'}}</text>
        </view>
      </view>
    </view>

    <view class="field-row no-border">
      <text class="field-label">详细地址</text>
      <input class="field-input field-right" placeholder="如：XX路XX小区" value="{{form.address}}" bindinput="onInput" data-field="address" />
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">价格信息</text>
    </view>

    <view class="field-row">
      <text class="field-label">总价</text>
      <view class="unit-wrap">
        <input class="field-input field-right" type="digit" placeholder="出售房源填写" value="{{form.total_price}}" bindinput="onInput" data-field="total_price" />
        <text class="unit">万元</text>
      </view>
    </view>

    <view class="field-row">
      <text class="field-label">月租</text>
      <view class="unit-wrap">
        <input class="field-input field-right" type="digit" placeholder="租赁房源填写" value="{{form.monthly_rent}}" bindinput="onInput" data-field="monthly_rent" />
        <text class="unit">元/月</text>
      </view>
    </view>

    <view class="field-row no-border">
      <text class="field-label">佣金</text>
      <view class="unit-wrap">
        <input class="field-input field-right" type="digit" placeholder="成交后佣金金额" value="{{form.commission}}" bindinput="onInput" data-field="commission" />
        <text class="unit">元</text>
      </view>
    </view>
  </view>

  <!-- 房源详情 -->
  <view class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">房源详情</text>
    </view>

    <view class="field-row">
      <text class="field-label">建筑面积<text class="req"> *</text></text>
      <view class="unit-wrap">
        <input class="field-input field-right" type="digit" placeholder="请输入" value="{{form.area}}" bindinput="onInput" data-field="area" />
        <text class="unit">㎡</text>
      </view>
    </view>

    <view class="field-row">
      <text class="field-label">楼层</text>
      <view class="floor-wrap">
        <input class="floor-input" type="number" placeholder="当前层" value="{{form.floor}}" bindinput="onInput" data-field="floor" />
        <text class="floor-sep">/</text>
        <input class="floor-input" type="number" placeholder="总层数" value="{{form.total_floors}}" bindinput="onInput" data-field="total_floors" />
        <text class="unit">层</text>
      </view>
    </view>

    <view class="rooms-card">
      <view class="room-col">
        <text class="room-label">卧室</text>
        <view class="stepper">
          <view class="step-btn" bindtap="onStepper" data-field="bedrooms" data-op="dec">−</view>
          <text class="step-val">{{form.bedrooms || 0}}</text>
          <view class="step-btn" bindtap="onStepper" data-field="bedrooms" data-op="inc">+</view>
        </view>
      </view>
      <view class="room-sep"></view>
      <view class="room-col">
        <text class="room-label">客厅</text>
        <view class="stepper">
          <view class="step-btn" bindtap="onStepper" data-field="living_rooms" data-op="dec">−</view>
          <text class="step-val">{{form.living_rooms || 0}}</text>
          <view class="step-btn" bindtap="onStepper" data-field="living_rooms" data-op="inc">+</view>
        </view>
      </view>
      <view class="room-sep"></view>
      <view class="room-col">
        <text class="room-label">卫生间</text>
        <view class="stepper">
          <view class="step-btn" bindtap="onStepper" data-field="bathrooms" data-op="dec">−</view>
          <text class="step-val">{{form.bathrooms || 0}}</text>
          <view class="step-btn" bindtap="onStepper" data-field="bathrooms" data-op="inc">+</view>
        </view>
      </view>
    </view>

    <view class="field-row tag-field">
      <text class="field-label">装修情况</text>
      <view class="tag-group">
        <view wx:for="{{decorations}}" wx:key="*this" class="pill {{form.decoration === item ? 'pill-active' : ''}}" data-val="{{item}}" bindtap="onDecorationSelect">{{item}}</view>
      </view>
    </view>

    <view class="field-row tag-field no-border">
      <text class="field-label">朝向</text>
      <view class="tag-group">
        <view wx:for="{{directions}}" wx:key="*this" class="pill {{form.direction === item ? 'pill-active' : ''}}" data-val="{{item}}" bindtap="onDirectionSelect">{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 房源描述（富文本） -->
  <view class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">房源描述</text>
    </view>
    <view class="editor-toolbar">
      <view class="toolbar-btn" bindtap="onFormat" data-name="bold"><text class="tb-bold">B</text></view>
      <view class="toolbar-btn" bindtap="onFormat" data-name="italic"><text class="tb-italic">I</text></view>
      <view class="toolbar-btn" bindtap="onFormat" data-name="underline"><text class="tb-underline">U</text></view>
      <view class="toolbar-sep"></view>
      <view class="toolbar-btn" bindtap="onFormat" data-name="list" data-value="ordered"><text>有序</text></view>
      <view class="toolbar-btn" bindtap="onFormat" data-name="list" data-value="bullet"><text>无序</text></view>
      <view class="toolbar-sep"></view>
      <view class="toolbar-btn" bindtap="onEditorInsertImage"><text>图片</text></view>
    </view>
    <editor
      id="desc-editor"
      class="desc-editor"
      placeholder="描述房源特点、周边配套、交通等..."
      bindinput="onEditorInput"
      bindready="onEditorReady"
    />
  </view>

  <!-- 房源状态（仅编辑） -->
  <view wx:if="{{isEdit}}" class="card">
    <view class="card-header">
      <view class="header-bar"></view>
      <text class="card-title">房源状态</text>
    </view>
    <view class="status-row">
      <view wx:for="{{statuses}}" wx:key="value" class="status-pill s-{{item.value}} {{status === item.value ? 's-active' : ''}}" data-val="{{item.value}}" bindtap="onStatusSelect">{{item.label}}</view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="submit-btn" bindtap="onSubmit">{{isEdit ? '保存修改' : '立即发布'}}</view>
  </view>

</view>
