<view wx:if="{{article}}" class="page">
  <image wx:if="{{article.coverImageUrl}}" class="cover" src="{{article.coverImageUrl}}" mode="aspectFill" />
  <view class="content-wrap">
    <view class="article-title">{{article.title}}</view>
    <view class="article-meta">
      <text>{{article.category}}</text>
      <text class="dot">·</text>
      <text>{{article.publishedAt}}</text>
      <text class="dot">·</text>
      <text>{{article.view_count}}次阅读</text>
    </view>
    <rich-text class="article-content" nodes="{{article.content}}" />
  </view>
</view>

<!-- 骨架屏 -->
<view wx:elif="{{loading && !loadFailed}}" class="loading-page">
  <view class="sk-cover"></view>
  <view class="sk-content">
    <view class="sk-line w-80"></view>
    <view class="sk-line w-60"></view>
    <view class="sk-line w-40"></view>
    <view class="sk-line"></view>
    <view class="sk-line"></view>
    <view class="sk-line w-60"></view>
  </view>
</view>

<!-- 加载失败 -->
<view wx:else class="loading-page" bindtap="onReload">
  <view class="error-icon">😞</view>
  <text>加载失败，点击重试</text>
</view>
