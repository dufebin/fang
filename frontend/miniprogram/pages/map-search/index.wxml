<view class="page">
  <!-- 地图 -->
  <map
    id="propertyMap"
    class="map"
    latitude="{{center.lat}}"
    longitude="{{center.lng}}"
    scale="{{scale}}"
    markers="{{markers}}"
    show-location
    bindmarkertap="onMarkerTap"
    bindregionchange="onRegionChange"
  />

  <!-- 顶部筛选与定位 -->
  <view class="top-bar">
    <view class="filter-btn glass" bindtap="onFilterTap">
      <text class="icon-filter">⎈</text>
      <text>条件筛选</text>
      <view wx:if="{{hasFilter}}" class="filter-dot" />
    </view>
    <view class="location-btn glass hover-scale" bindtap="onLocate">
      <text class="loc-icon-text">⌖</text>
    </view>
  </view>

  <!-- 悬浮半屏抽屉 (Bottom Sheet) -->
  <view class="bottom-sheet {{selectedProperty ? 'sheet-show' : ''}}">
    <view class="sheet-backdrop" bindtap="onClosePanel" wx:if="{{selectedProperty}}"></view>
    <view class="sheet-content glass">
      <view class="sheet-handle" bindtap="onClosePanel" />
      <view wx:if="{{selectedProperty}}" class="sheet-card">
        <property-card property="{{selectedProperty}}" compact="{{false}}" />
      </view>
    </view>
  </view>

  <filter-drawer show="{{showFilter}}" bind:close="onFilterClose" bind:confirm="onFilterConfirm" />
</view>
