.page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: var(--color-bg);
}

.map {
  width: 100%;
  height: 100vh;
}

/* 顶部操作栏 */
.top-bar {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
  pointer-events: none; /* Let map receive touches where there's no button */
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  position: relative;
  pointer-events: auto;
  box-shadow: 0 4rpx 16rpx rgba(15, 118, 110, 0.1);
  border: 1rpx solid rgba(255,255,255,0.4);
}

.icon-filter {
  font-size: 32rpx;
  color: var(--color-primary);
}

.filter-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-price);
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  border: 2rpx solid #fff;
}

.location-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  box-shadow: 0 4rpx 16rpx rgba(15, 118, 110, 0.1);
  border: 1rpx solid rgba(255,255,255,0.4);
}

.loc-icon-text {
  font-size: 40rpx;
  color: var(--color-primary);
  line-height: 1;
  font-weight: 600;
}

/* 悬浮半屏抽屉 (Bottom Sheet) */
.bottom-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 200;
  pointer-events: none;
}

.sheet-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent; /* Invisible backdrop to catch taps to close */
  pointer-events: auto;
}

.sheet-content {
  position: absolute;
  bottom: -600rpx;
  left: 0;
  right: 0;
  padding: 0 30rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 40rpx 40rpx 0 0;
  transition: bottom 0.35s cubic-bezier(0.175, 0.885, 0.32, 1);
  pointer-events: auto;
  box-shadow: 0 -10rpx 40rpx rgba(15, 118, 110, 0.08);
  border-top: 1rpx solid rgba(255,255,255,0.6);
}

.sheet-show .sheet-content {
  bottom: 0;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: rgba(15, 118, 110, 0.2);
  border-radius: 4rpx;
  margin: 20rpx auto 30rpx;
}

.sheet-card {
  width: 100%;
}
