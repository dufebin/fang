<view class="page">
  <!-- 用户信息头部 -->
  <view class="profile-header" bindtap="{{isLoggedIn ? '' : 'onLogin'}}">
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:if="{{isLoggedIn}}" class="user-info">
      <view class="nickname">{{userInfo.nickname || '用户'}}</view>
      <view wx:if="{{isAgent}}" class="agent-badge">经纪人</view>
    </view>
    <view wx:else class="user-info">
      <view class="nickname">点击登录</view>
      <view class="login-hint">登录享受更多服务</view>
    </view>
  </view>

  <!-- 数据概览（已登录） -->
  <view wx:if="{{isLoggedIn}}" class="stats-row">
    <view class="stat-item" bindtap="onFavorites">
      <text class="stat-num">{{stats.favoriteCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item" bindtap="onAppointments">
      <text class="stat-num">{{stats.appointmentCount}}</text>
      <text class="stat-label">预约</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item" bindtap="onHistory">
      <text class="stat-num">{{stats.historyCount}}</text>
      <text class="stat-label">浏览</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-group">
    <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="onFavorites">
      <text class="menu-label">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="onAppointments">
      <text class="menu-label">我的预约</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="onHistory">
      <text class="menu-label">浏览历史</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="onNotifications">
      <text class="menu-label">消息通知</text>
      <view wx:if="{{unreadCount > 0}}" class="badge">{{unreadCount}}</view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" wx:if="{{isAgent}}" bindtap="onAgentWorkbench">
      <text class="menu-label">经纪人工作台</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isLoggedIn && !isAgent}}" bindtap="onApplyAgent">
      <text class="menu-label">申请成为经纪人</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="onLoanCalc">
      <text class="menu-label">贷款计算器</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onArticles">
      <text class="menu-label">房产资讯</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="onLogout">退出登录</view>
</view>
