.page {
  background: var(--color-bg);
  min-height: 100vh;
}

.pb-safe {
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

/* 渐变头部 Hero Header */
.hero-header {
  position: relative;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-cta) 100%);
  padding: 80rpx 40rpx 140rpx;
  overflow: hidden;
}

.hero-bg-glow {
  position: absolute;
  top: -100rpx;
  right: -50rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%);
  border-radius: 50%;
}

.user-profile-flex {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar-glass {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  background: rgba(255,255,255,0.2);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.nickname-lg {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.user-meta, .login-hint-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.agent-badge-glass {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8px);
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.badge-icon {
  color: #fbbf24;
  font-size: 24rpx;
}

.profile-arrow {
  color: rgba(255,255,255,0.5);
  font-size: 48rpx;
  font-weight: 300;
}

/* 悬浮数据卡片 */
.stats-overlap-card {
  margin: -80rpx 30rpx 40rpx;
  border-radius: 24rpx;
  padding: 36rpx 0;
  display: flex;
  position: relative;
  z-index: 20;
  background: rgba(255, 255, 255, 0.9);
}

.shadow-lg {
  box-shadow: 0 12rpx 32rpx rgba(15, 118, 110, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num-font {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  font-family: var(--font-number);
}

.stat-lbl {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.stat-vertical-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e2e8f0;
  align-self: center;
}

/* 菜单区 */
.menu-section {
  margin-bottom: 40rpx;
}

.menu-title {
  padding: 0 40rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-muted);
}

.menu-group {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 30rpx;
  overflow: hidden;
}

.shadow-sm {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 100rpx;
  right: 30rpx;
  height: 1rpx;
  background: #f1f5f9;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-right: 24rpx;
}

.icon-red { background: rgba(225, 29, 72, 0.1); color: #E11D48; }
.icon-blue { background: rgba(3, 105, 161, 0.1); color: #0369A1; }
.icon-yellow { background: rgba(245, 158, 11, 0.1); color: #F59E0B; }
.icon-teal { background: rgba(15, 118, 110, 0.1); color: #0F766E; }
.icon-purple { background: rgba(139, 92, 246, 0.1); color: #8B5CF6; }
.icon-gray { background: #f1f5f9; color: #64748b; }

.menu-label {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

.menu-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  margin-left: 16rpx;
}

.badge-dot {
  background: #E11D48;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(225, 29, 72, 0.2);
}

.logout-btn {
  margin: 60rpx 30rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ef4444;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.mock-login-btn {
  display: none;
}

/* 密码弹窗 */
.pwd-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pwd-dialog {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 580rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.pwd-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
  text-align: center;
  margin-bottom: 36rpx;
}

.pwd-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1e293b;
  background: #f8fafc;
  box-sizing: border-box;
  letter-spacing: 8rpx;
  text-align: center;
}

.pwd-err {
  font-size: 24rpx;
  color: #ef4444;
  text-align: center;
  margin-top: 16rpx;
}

.pwd-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.pwd-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.pwd-cancel {
  background: #f1f5f9;
  color: #64748b;
}

.pwd-confirm {
  background: var(--color-primary, #0F766E);
  color: #fff;
}
