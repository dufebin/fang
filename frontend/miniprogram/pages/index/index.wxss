.page {
  background: #F0F9FF;
  min-height: 100vh;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0;
  padding: 16rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #EDF4FB;
}

.search-bar-inner {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F0F9FF;
  border: 1.5rpx solid #E0EEF8;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.45;
  flex-shrink: 0;
}

.search-placeholder {
  font-size: 28rpx;
  color: #aac5d9;
}

.banner-swiper {
  width: 100%;
  height: 340rpx;
}

.banner-img {
  width: 100%;
  height: 340rpx;
  display: block;
}

.quick-nav {
  display: flex;
  flex-wrap: nowrap;
  background: #fff;
  padding: 20rpx 0 16rpx;
}

.nav-item {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 20rpx;
  font-size: 20rpx;
  color: #444;
}

.nav-item:active .nav-icon-circle {
  opacity: 0.82;
}

.nav-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 10rpx;
}

.nav-icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EFF7FB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-bottom: 10rpx;
}

/* 必须在 .nav-icon-circle 之后定义，否则同优先级时被覆盖 */
.nav-green  { background: #D1FAE5; }
.nav-orange { background: #FEF3C7; }
.nav-blue   { background: #E0F2FE; }
.nav-pink   { background: #FFE4E6; }
.nav-teal   { background: #CCFBF1; }
.nav-indigo { background: #E0E7FF; }
.nav-purple { background: #EDE9FE; }

.section {
  margin: 16rpx 0 0;
  background: #fff;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 24rpx 24rpx 0 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-more {
  font-size: 26rpx;
  color: #0284C7;
}

.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.article-list {}

.article-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.article-item:last-child {
  border-bottom: none;
}

.article-thumb {
  width: 176rpx;
  height: 120rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #EFF7FB;
}

.article-info {
  flex: 1;
  margin-left: 24rpx;
}

.article-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #222;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-date {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 12rpx;
}
