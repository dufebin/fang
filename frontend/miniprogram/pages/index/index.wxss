.page {
  background: var(--color-bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 用户信息头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid #f1f5f9;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #e8f0f3;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
}

.agent-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 24rpx 0;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.agent-entry-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.agent-entry-arrow {
  font-size: 40rpx;
  color: #c0cad6;
  line-height: 1;
}

/* 房源列表 */
.list-wrap {
  padding: 24rpx 24rpx 0;
}

.loading-tip,
.load-more-tip,
.no-more {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-muted);
  font-size: 26rpx;
}
