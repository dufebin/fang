<view class="page">
  <!-- 顶部操作栏 -->
  <view class="top-bar">
    <view class="top-title">消息</view>
    <view class="top-add" bindtap="onNewChat">+</view>
  </view>

  <!-- 会话列表 -->
  <block wx:if="{{list.length}}">
    <view class="conv-item" wx:for="{{list}}" wx:key="peer_id" bindtap="onOpenChat"
          bindtouchstart="onConvTouchStart" bindtouchend="onConvTouchEnd" bindtouchcancel="onConvTouchEnd"
          data-peer-id="{{item.peer_id}}" data-peer-name="{{item.peer_name}}">
      <image class="conv-avatar" src="{{item.peer_avatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
      <view class="conv-info">
        <view class="conv-name-row">
          <text class="conv-name">{{item.peer_name || '用户'}}</text>
          <text class="conv-time">{{item.last_at_fmt}}</text>
        </view>
        <view class="conv-last-row">
          <text class="conv-last">{{item.last_message}}</text>
          <view wx:if="{{item.unread > 0}}" class="conv-badge">{{item.unread}}</view>
        </view>
      </view>
    </view>
  </block>
  <view wx:elif="{{!loading}}" class="empty-tip">暂无消息，点击右上角 + 开始聊天</view>

  <!-- 选择联系人弹窗 -->
  <view wx:if="{{showContacts}}" class="contacts-mask" catchtap="onCloseContacts">
    <view class="contacts-panel" catchtap="">
      <view class="contacts-title">选择联系人</view>
      <scroll-view class="contacts-list" scroll-y>
        <view class="contact-item" wx:for="{{contacts}}" wx:key="id" bindtap="onSelectContact" data-id="{{item.id}}" data-name="{{item.nickname}}">
          <image class="contact-avatar" src="{{item.avatar_url || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
          <text class="contact-name">{{item.nickname || '用户'}}</text>
        </view>
        <view wx:if="{{!contacts.length}}" class="contacts-empty">暂无其他用户</view>
      </scroll-view>
    </view>
  </view>
</view>
