.page {
  min-height: 100vh;
  background: #1a1a1a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 6rpx solid rgba(255,255,255,0.15);
  border-top-color: #0284C7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text { font-size: 28rpx; color: #aaa; }

.preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.tip { font-size: 24rpx; color: #888; }

.poster-image {
  width: 100%;
  max-width: 600rpx;
  border-radius: 16rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.5);
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
  width: 100%;
  max-width: 600rpx;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #0284C7;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.share-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: rgba(255,255,255,0.1);
  color: #ccc;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.error-icon { font-size: 72rpx; }
.error-text { font-size: 28rpx; color: #aaa; }
.retry-text { font-size: 24rpx; color: #0284C7; }

.offscreen-canvas {
  position: fixed;
  left: 0;
  top: 0;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}
