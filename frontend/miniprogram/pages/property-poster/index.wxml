<view class="page">
  <view wx:if="{{generating}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">生成海报中...</text>
  </view>

  <view wx:elif="{{posterPath}}" class="preview-wrap">
    <text class="tip">长按图片保存到相册</text>
    <image class="poster-image" src="{{posterPath}}" mode="aspectFit" show-menu-by-longpress />
    <view class="btn-row">
      <view class="save-btn" bindtap="onSave">保存到相册</view>
      <view class="share-btn" bindtap="onShareLink">复制推广链接</view>
    </view>
  </view>

  <view wx:elif="{{error}}" class="error-wrap" bindtap="onRetry">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <text class="retry-text">点击重试</text>
  </view>

  <!-- 离屏 Canvas，用于绘制海报 -->
  <canvas type="2d" id="poster-canvas" class="offscreen-canvas" />
</view>
