.page {
  background: #F0F9FF;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.stats-card {
  background: #0284C7;
  padding: 32rpx;
}

.stats-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.action-row {
  display: flex;
  background: #fff;
  margin-bottom: 16rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  font-size: 22rpx;
  color: #555;
  gap: 8rpx;
  border-right: 1rpx solid #f5f5f5;
}

.action-item:last-child { border-right: none; }

.action-icon-text {
  font-size: 36rpx;
  color: #0284C7;
}

.tab-bar {
  display: flex;
  background: #fff;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
}

.tab-active {
  color: #0284C7;
  font-weight: 500;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #0284C7;
  border-radius: 2rpx;
}

.list-wrap { padding: 0 24rpx; }

.appt-list { padding: 0 24rpx; }

.appt-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.appt-info { flex: 1; }

.appt-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #222;
}

.appt-prop, .appt-time {
  font-size: 24rpx;
  color: #888;
  margin-top: 6rpx;
}

.appt-btns {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.appt-btn-confirm, .appt-btn-cancel {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.appt-btn-confirm { background: #0284C7; color: #fff; }
.appt-btn-cancel { background: #F0F9FF; color: #888; }

.property-wrap { margin-bottom: 16rpx; }

.property-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 12rpx 16rpx;
  background: #fff;
  border-top: 1rpx solid #f5f5f5;
  border-radius: 0 0 16rpx 16rpx;
  margin-top: -16rpx;
}

.action-edit {
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: 1rpx solid #0284C7;
  color: #0284C7;
}

.action-delete {
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F0F9FF;
  color: #888;
}
