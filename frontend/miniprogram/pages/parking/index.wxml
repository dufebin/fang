<view class="page">
  <!-- 顶部状态条 -->
  <view class="topbar">
    <view class="topbar-left">
      <view class="topbar-title">智慧停车管理平台</view>
      <view class="topbar-sub">{{today}}  {{now}}</view>
    </view>
    <view class="topbar-status">
      <view class="dot-online"></view>
      <text>系统正常</text>
    </view>
  </view>

  <!-- 概览卡片 -->
  <view class="overview">
    <view class="ov-card ov-primary">
      <view class="ov-num">{{stats.total}}</view>
      <view class="ov-lbl">总车位</view>
    </view>
    <view class="ov-card">
      <view class="ov-num ov-green">{{stats.free}}</view>
      <view class="ov-lbl">空余</view>
    </view>
    <view class="ov-card">
      <view class="ov-num ov-orange">{{stats.occupied}}</view>
      <view class="ov-lbl">已停</view>
    </view>
    <view class="ov-card">
      <view class="ov-num ov-blue">¥{{stats.todayIncome}}</view>
      <view class="ov-lbl">今日收入</view>
    </view>
  </view>

  <!-- 区域占用 -->
  <view class="section">
    <view class="section-head">
      <text class="section-title">区域占用</text>
      <text class="section-more">实时</text>
    </view>
    <view class="zones">
      <view class="zone-row" wx:for="{{zones}}" wx:key="name">
        <view class="zone-name">{{item.name}}</view>
        <view class="zone-bar">
          <view class="zone-bar-inner" style="width: {{item.rate}}%"></view>
        </view>
        <view class="zone-meta">{{item.used}}/{{item.total}}</view>
        <view class="zone-rate">{{item.rate}}%</view>
      </view>
    </view>
  </view>

  <!-- 车位分布 A1~A30 -->
  <view class="section">
    <view class="section-head">
      <text class="section-title">A区 地上一层 · 车位分布</text>
      <view class="legend">
        <view class="lg lg-free"></view><text>空余</text>
        <view class="lg lg-occupied"></view><text>已停</text>
        <view class="lg lg-maintain"></view><text>维护</text>
      </view>
    </view>
    <view class="spots-grid">
      <view class="spot spot-{{item.state === 0 ? 'free' : item.state === 1 ? 'occupied' : 'maintain'}}" wx:for="{{spots}}" wx:key="code">
        <text class="spot-code">{{item.code}}</text>
      </view>
    </view>
  </view>

  <!-- 今日车流 -->
  <view class="section">
    <view class="section-head">
      <text class="section-title">今日车流</text>
      <text class="section-more">较昨日 {{stats.flowDelta > 0 ? '+' : ''}}{{stats.flowDelta}}%</text>
    </view>
    <view class="flow-row">
      <view class="flow-item">
        <view class="flow-num">{{stats.todayFlow}}</view>
        <view class="flow-lbl">总车次</view>
      </view>
      <view class="flow-item">
        <view class="flow-num">{{stats.enter}}</view>
        <view class="flow-lbl">入场</view>
      </view>
      <view class="flow-item">
        <view class="flow-num">{{stats.exit}}</view>
        <view class="flow-lbl">出场</view>
      </view>
      <view class="flow-item">
        <view class="flow-num">{{stats.members}}</view>
        <view class="flow-lbl">月卡会员</view>
      </view>
    </view>
  </view>

  <!-- 出入记录 -->
  <view class="section" id="sec-records">
    <view class="section-head">
      <text class="section-title">最近出入</text>
      <text class="section-more">查看全部 ›</text>
    </view>
    <view class="records">
      <view class="rec-row {{item.status === 'warn' ? 'rec-warn' : ''}}" wx:for="{{records}}" wx:key="plate">
        <view class="rec-plate">{{item.plate}}</view>
        <view class="rec-type rec-type-{{item.typeKey}}">{{item.type}}</view>
        <view class="rec-action">{{item.action}}</view>
        <view class="rec-fee" wx:if="{{item.fee}}">{{item.fee}}</view>
        <view class="rec-fee rec-fee-none" wx:elif="{{item.action === '入场'}}">—</view>
        <view class="rec-fee rec-fee-none" wx:else>—</view>
        <view class="rec-time">{{item.time}}</view>
      </view>
    </view>
  </view>

  <!-- 告警 -->
  <view class="section" id="sec-alerts">
    <view class="section-head">
      <text class="section-title" bindtap="onTitleTap">设备告警</text>
      <text class="section-more">{{alerts.length}} 条</text>
    </view>
    <view class="alerts">
      <view class="alert alert-{{item.level}}" wx:for="{{alerts}}" wx:key="text">
        <view class="alert-icon">{{item.level === 'warn' ? '!' : 'i'}}</view>
        <view class="alert-text">{{item.text}}</view>
        <view class="alert-time">{{item.time}}</view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="actionbar">
    <view class="action-btn {{activeTab === 'home' ? 'action-active' : ''}}" bindtap="onGoTop">首页</view>
    <view class="action-btn {{activeTab === 'records' ? 'action-active' : ''}}" bindtap="onGoRecords">最近出入</view>
    <view class="action-btn {{activeTab === 'alerts' ? 'action-active' : ''}}" bindtap="onGoAlerts">告警</view>
  </view>

  <!-- 隐藏入口：密码弹窗 -->
  <view wx:if="{{showPasswordModal}}" class="pwd-mask" catchtap="onMaskTap">
    <view class="pwd-dialog" catchtap="onDialogTap">
      <view class="pwd-title">请输入密码</view>
      <input class="pwd-input" type="text" password placeholder="请输入密码" value="{{passwordInput}}" bindinput="onPasswordInput" maxlength="10" />
      <view class="pwd-err" wx:if="{{passwordError}}">密码错误，请重试</view>
      <view class="pwd-actions">
        <view class="pwd-btn pwd-cancel" bindtap="onPasswordCancel">取消</view>
        <view class="pwd-btn pwd-confirm" bindtap="onPasswordConfirm">确认</view>
      </view>
    </view>
  </view>
</view>
