.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f2f5;
}

.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f0f2f5;
  z-index: 9999;
}

.msg-scroll {
  flex: 1;
  overflow: hidden;
}

.msg-list {
  padding: 24rpx 20rpx 32rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.row-left {
  flex-direction: row;
}

.row-right {
  flex-direction: row-reverse;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #e2e8f0;
}

.msg-main {
  display: flex;
  flex-direction: column;
  max-width: 76%;
  margin: 0 20rpx;
}

.row-right .msg-main {
  align-items: flex-end;
}

.row-left .msg-main {
  align-items: flex-start;
}

.msg-meta {
  margin-bottom: 8rpx;
}

.from-name {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bubble {
  padding: 18rpx 26rpx;
  border-radius: 24rpx;
  word-break: break-all;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}

.bubble-peer {
  background: #fff;
  border-top-left-radius: 6rpx;
}

.bubble-mine {
  background: #0F766E;
  border-top-right-radius: 6rpx;
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.5;
}

.bubble-peer .bubble-text {
  color: #1e293b;
}

.bubble-mine .bubble-text {
  color: #fff;
}

.msg-time {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  padding: 0 4rpx;
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e2e8f0;
  gap: 16rpx;
}

.input-box {
  flex: 1;
  height: 80rpx;
  background: #f4f6f8;
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1e293b;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: #e2e8f0;
  color: #94a3b8;
  flex-shrink: 0;
}

.send-active {
  background: #0F766E;
  color: #fff;
}
