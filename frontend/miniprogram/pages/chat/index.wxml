<view class="page">
  <!-- 隐私遮罩：进入后台时盖住聊天内容，防止后台快照泄露 -->
  <view wx:if="{{privacyMasked}}" class="privacy-mask"></view>
  <!-- 消息列表 -->
  <scroll-view class="msg-scroll" scroll-y scroll-into-view="{{scrollTo}}" scroll-with-animation enable-flex>
    <view class="msg-list">
      <view wx:for="{{messages}}" wx:key="id"
            class="msg-row {{item.is_mine ? 'row-right' : 'row-left'}}"
            id="msg-{{item.id}}">
        <image class="avatar" src="{{item.from_avatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
        <view class="msg-main">
          <view class="msg-meta">
            <text class="from-name">{{item.from_name}}</text>
          </view>
          <view class="bubble {{item.is_mine ? 'bubble-mine' : 'bubble-peer'}}"
                bindtouchstart="onBubbleTouchStart" bindtouchend="onBubbleTouchEnd" bindtouchcancel="onBubbleTouchEnd"
                data-id="{{item.id}}">
            <text class="bubble-text">{{item.content}}</text>
          </view>
          <view class="msg-time">{{item.time_fmt}}</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部输入区 -->
  <view class="input-bar">
    <input class="input-box" placeholder="输入消息…" value="{{inputText}}" bindinput="onInput" confirm-type="send" bindconfirm="onSend" adjust-position maxlength="500" />
    <view class="send-btn {{inputText ? 'send-active' : ''}}" bindtap="onSend">发送</view>
  </view>
</view>
