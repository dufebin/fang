.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 28rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.loan-amount-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #E84040;
}

.form-input {
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #222;
  width: 100%;
  box-sizing: border-box;
}

.ratio-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ratio-tag {
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #555;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.ratio-active {
  color: #E84040;
  background: #fff0f0;
  border-color: #E84040;
}

.calc-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #E84040;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 12rpx;
}

/* 结果 */
.result-card {}

.result-row {
  display: flex;
  justify-content: space-between;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.result-label {
  font-size: 22rpx;
  color: #888;
}

.result-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
}

.red { color: #E84040; }

.schedule-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.schedule-header,
.schedule-row {
  display: flex;
  font-size: 22rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.schedule-header {
  color: #aaa;
  font-weight: 500;
}

.schedule-row {
  color: #444;
}

.schedule-header text,
.schedule-row text {
  flex: 1;
  text-align: center;
}
