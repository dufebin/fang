/* ────────────────────────────────────────────
   房源详情页样式
   ──────────────────────────────────────────── */

.page {
  background: var(--color-bg);
  min-height: 100vh;
}

.pb-safe {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 加载 & 错误状态 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(15, 118, 110, 0.15);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ── 媒体画廊 ─────────────────────────────── */
.swiper-wrap {
  position: relative;
  width: 100%;
  height: 560rpx;
  background: #e2e8f0;
}

.img-swiper, .swiper-img, .swiper-video {
  width: 100%;
  height: 100%;
}

.media-overlay-top {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  pointer-events: none;
}

.media-tags {
  display: flex;
  gap: 16rpx;
}

.tag-glass {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(8px);
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.tag-success {
  color: #059669;
  background: rgba(209, 250, 229, 0.92);
}

.media-overlay-bottom {
  position: absolute;
  bottom: 40rpx;
  right: 30rpx;
  pointer-events: none;
}

.img-count-glass {
  background: rgba(0, 0, 0, 0.48);
  backdrop-filter: blur(8px);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-family: var(--font-number);
  letter-spacing: 2rpx;
}

/* ── 价格卡片（浮在图片上） ──────────────── */
.card-top-radius {
  margin-top: -30rpx;
  border-radius: 40rpx 40rpx 0 0;
  position: relative;
  z-index: 10;
  padding-top: 40rpx;
}

.shadow-sm {
  box-shadow: 0 -8rpx 24rpx rgba(0,0,0,0.04);
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.price-col {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.price-main-huge {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-price);
  font-family: var(--font-number);
  line-height: 1;
}

.unit-price-sub {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-family: var(--font-number);
}

.action-icons {
  display: flex;
  gap: 16rpx;
}

.action-btn-small {
  min-width: 88rpx;
  padding: 12rpx 24rpx;
  background: #f8fafc;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
  border: 1rpx solid rgba(15, 118, 110, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.property-title-lg {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 28rpx;
}

/* ── 三列核心参数（户型/面积/楼层） ────── */
.property-meta-flex {
  display: flex;
  align-items: stretch;
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 24rpx;
}

.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.meta-val {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  font-family: var(--font-number);
}

.meta-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.meta-divider {
  width: 1rpx;
  height: 44rpx;
  background: #e2e8f0;
  align-self: center;
}

/* ── 区域位置行 ───────────────────────────── */
.district-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
  padding: 6rpx 0 4rpx;
}

.loc-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
}

/* ── 佣金提示栏 ───────────────────────────── */
.commission-banner {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.commission-badge {
  background: #F59E0B;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.commission-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #B45309;
  font-family: var(--font-number);
}

/* ── 标签列表 ─────────────────────────────── */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* ── 房源数据区（热度 / 时间 / 状态 + 贷款入口） */
.stat-section {
  background: #fff;
  padding: 28rpx 30rpx 0;
  margin-bottom: 16rpx;
}

.signal-grid {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.signal-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.signal-val {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  font-family: var(--font-number);
}

.signal-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.signal-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

/* ── 信任认证标签 ─────────────────────────── */
.trust-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.trust-pill {
  font-size: 22rpx;
  color: var(--color-primary);
  background: rgba(15, 118, 110, 0.08);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* ── 贷款估算入口（精简行） ──────────────── */
.loan-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.loan-entry-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.loan-entry-icon {
  width: 60rpx;
  height: 60rpx;
  background: rgba(15, 118, 110, 0.08);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.3;
}

.loan-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.loan-entry-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loan-entry-val {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-cta);
  font-family: var(--font-number);
}

.loan-entry-arrow {
  font-size: 40rpx;
  color: #cbd5e1;
  font-weight: 300;
  line-height: 1;
}

/* ── 通用 Section ─────────────────────────── */
.section {
  background: #fff;
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

/* 覆盖 app.wxss section-title-accent，补充 margin */
.section-title-accent {
  margin-bottom: 24rpx;
}

/* ── 核心卖点 2列网格 ──────────────────────── */
.highlight-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.highlight-card {
  width: calc(50% - 8rpx);
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.highlight-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.highlight-value {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 700;
}

.highlight-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.4;
}

/* ── 位置与交易信息 ───────────────────────── */
.deal-info-list {
  display: flex;
  flex-direction: column;
}

.deal-info-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f8fafc;
}

.deal-info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.deal-info-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.deal-info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
  text-align: right;
  line-height: 1.5;
}

/* ── 基本信息网格 ─────────────────────────── */
.info-grid-clean {
  display: flex;
  flex-wrap: wrap;
  row-gap: 20rpx;
}

.info-cell {
  width: 50%;
  display: flex;
  gap: 16rpx;
  font-size: 28rpx;
}

.info-lbl {
  color: var(--color-text-muted);
  width: 80rpx;
  flex-shrink: 0;
}

.info-txt {
  color: var(--color-text);
  font-weight: 500;
}

/* ── 房源描述 ─────────────────────────────── */
.description-rich {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
}

/* ── 认领区 ───────────────────────────────── */
.claim-section-new {
  margin-bottom: 40rpx;
}

.claim-box {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx dashed #cbd5e1;
}

.claim-box.active {
  background: #f0fdf4;
  border-color: #bbf7d0;
  border-style: solid;
}

.claim-header {
  margin-bottom: 24rpx;
}

.claim-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.claim-subtitle {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.claim-input-glass {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e2e8f0;
}

.claim-input-field {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
}

.claim-ph {
  color: #94a3b8;
}

.claim-unit {
  color: var(--color-text-muted);
  font-weight: 500;
  margin-left: 16rpx;
}

.claim-status-badge-new {
  display: inline-flex;
  align-items: center;
  background: #dcfce7;
  color: #16a34a;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 600;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.claim-commission-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ea580c;
  margin-bottom: 30rpx;
}

.claim-actions-flex {
  display: flex;
}

.ml-20 {
  margin-left: 20rpx;
}

/* ── 底部占位 & 悬浮操作栏 ───────────────── */
.bottom-padding {
  height: 24rpx;
}

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.action-bar-inner {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  height: 110rpx;
  gap: 16rpx;
}

.action-icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  gap: 4rpx;
}

.icon-large {
  font-size: 44rpx;
  line-height: 1;
}

.action-btn-text {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.action-main-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, var(--color-cta) 0%, var(--color-primary) 100%);
  border-radius: 44rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(3, 105, 161, 0.25);
}
