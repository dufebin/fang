.page {
  background: #F0F9FF;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-size: 28rpx;
  color: #bbb;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 图片轮播 */
.swiper-wrap {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: #111;
}

.img-swiper {
  width: 100%;
  height: 480rpx;
}

.swiper-img {
  width: 100%;
  height: 480rpx;
}

.swiper-video {
  width: 100%;
  height: 480rpx;
  background: #000;
}

.img-count {
  position: absolute;
  bottom: 20rpx;
  right: 24rpx;
  background: rgba(0,0,0,0.45);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.tag-type {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(2,132,199,0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-verified {
  position: absolute;
  top: 20rpx;
  left: 120rpx;
  background: rgba(82,196,26,0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

/* 价格块 */
.price-block {
  background: #fff;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #0284C7;
}

.edit-btn {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  background: #E0F2FE;
  color: #0284C7;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid #0284C7;
}

.fav-btn {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.fav-active {
  color: #0284C7;
}

.property-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  margin-top: 12rpx;
}

.property-meta {
  font-size: 26rpx;
  color: #888;
  margin-top: 12rpx;
}

.dot {
  margin: 0 8rpx;
  color: #ddd;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.prop-tag {
  font-size: 22rpx;
  color: #0284C7;
  background: #E0F2FE;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
}

/* 通用 section */
.section {
  background: #fff;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  padding: 10rpx 0;
  display: flex;
  justify-content: space-between;
  padding-right: 20rpx;
}

.info-label {
  font-size: 26rpx;
  color: #888;
}

.info-val {
  font-size: 26rpx;
  color: #333;
}

/* 描述 */
.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* 贷款入口 */
.loan-entry {
  background: #fff;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.loan-val {
  color: #0284C7;
  font-weight: 600;
  flex: 1;
}

.loan-hint {
  font-size: 24rpx;
  color: #888;
}

/* 预约 */
.appt-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.appt-picker {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  background: #F0F9FF;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
}

.appt-note-wrap {
  margin-bottom: 20rpx;
}

.appt-note {
  width: 100%;
  min-height: 120rpx;
  background: #F0F9FF;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.appt-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #0284C7;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 佣金展示行 */
.commission-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.commission-label {
  font-size: 22rpx;
  color: #fff;
  background: #F59E0B;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.commission-val {
  font-size: 28rpx;
  color: #D97706;
  font-weight: 700;
}

/* ── 认领并推广区块 ── */
.claim-section {
  padding-bottom: 36rpx;
}

.claim-desc {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

/* 未认领 */
.claim-form {
  margin-bottom: 28rpx;
}

.claim-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
}

.claim-input-wrap {
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
}

.claim-commission-input {
  flex: 1;
  height: 92rpx;
  font-size: 30rpx;
  color: #1E293B;
  background: transparent;
}

.claim-placeholder {
  color: #CBD5E1;
  font-size: 26rpx;
}

.claim-btn {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #0284C7 0%, #0369A1 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(2, 132, 199, 0.35);
}

/* 已认领 */
.claim-status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.claim-status-badge {
  background: #DCFCE7;
  color: #16A34A;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.claim-commission-pill {
  background: #FEF3C7;
  color: #D97706;
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.claim-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.claim-share-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #0284C7 0%, #0369A1 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(2, 132, 199, 0.30);
}

.claim-cancel-btn {
  width: 180rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #F1F5F9;
  color: #94A3B8;
  border-radius: 44rpx;
  font-size: 26rpx;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
