.page {
  background: var(--color-bg);
  min-height: 100vh;
}

.pb-safe {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(15, 118, 110, 0.2);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin { 100% { transform: rotate(360deg); } }

.error-emoji {
  font-size: 80rpx;
}

/* 轮播图 Media Gallery */
.swiper-wrap {
  position: relative;
  width: 100%;
  height: 560rpx;
  background: #e2e8f0;
}

.img-swiper, .swiper-img, .swiper-video {
  width: 100%;
  height: 100%;
}

.media-overlay-top {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  justify-content: space-between;
  pointer-events: none;
}

.media-tags {
  display: flex;
  gap: 16rpx;
}

.tag-glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(8px);
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.tag-success {
  color: #059669;
  background: rgba(209, 250, 229, 0.9);
}

.media-overlay-bottom {
  position: absolute;
  bottom: 40rpx;
  right: 30rpx;
  pointer-events: none;
}

.img-count-glass {
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8px);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-family: var(--font-number);
  letter-spacing: 2rpx;
}

/* 顶部圆角层卡片 (上浮在图片上) */
.card-top-radius {
  margin-top: -30rpx;
  border-radius: 40rpx 40rpx 0 0;
  position: relative;
  z-index: 10;
  padding-top: 40rpx;
}

.shadow-sm {
  box-shadow: 0 -8rpx 24rpx rgba(0,0,0,0.04);
}

/* 价格块 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.price-main-huge {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-price);
  font-family: var(--font-number);
  line-height: 1;
}

.action-icons {
  display: flex;
  gap: 20rpx;
}

.action-btn-small {
  padding: 12rpx 24rpx;
  background: var(--color-bg);
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
  border: 1rpx solid rgba(15, 118, 110, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.property-title-lg {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 30rpx;
}

/* 核心信息横向排列 */
.property-meta-flex {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-top: 1rpx solid rgba(0,0,0,0.04);
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}

.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.meta-val {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-price); /* highlight key info */
  font-family: var(--font-number);
}

.meta-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.meta-divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.06);
}

/* 地址行 */
.district-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  padding: 10rpx 0;
}

.icon-location {
  font-size: 32rpx;
}

/* 佣金 Banner */
.commission-banner {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.commission-badge {
  background: #F59E0B;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.commission-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #B45309;
  font-family: var(--font-number);
}

/* 贷款 Banner */
.loan-banner {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(15, 118, 110, 0.05);
}

.loan-banner-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-calc {
  font-size: 40rpx;
}

.loan-banner-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.loan-banner-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loan-banner-val {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-cta);
  font-family: var(--font-number);
}

.loan-banner-arrow {
  color: #cbd5e1;
  font-weight: 700;
}

/* 基础信息网格 */
.info-grid-clean {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx 0;
}

.info-cell {
  width: 50%;
  display: flex;
  gap: 24rpx;
  font-size: 28rpx;
}

.info-lbl {
  color: var(--color-text-muted);
  width: 80rpx;
}

.info-txt {
  color: var(--color-text);
  font-weight: 500;
}

.description-rich {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
}

/* 认领区 */
.claim-section-new {
  margin-bottom: 40rpx;
}

.claim-box {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx dashed #cbd5e1;
}

.claim-box.active {
  background: #f0fdf4;
  border-color: #bbf7d0;
}

.claim-header {
  margin-bottom: 24rpx;
}

.claim-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.claim-subtitle {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.claim-input-glass {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.02);
}

.claim-input-field {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
}

.claim-ph {
  color: #94a3b8;
}

.claim-unit {
  color: var(--color-text);
  font-weight: 500;
  margin-left: 16rpx;
}

.claim-status-badge-new {
  display: inline-block;
  background: #dcfce7;
  color: #16a34a;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 600;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.claim-commission-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ea580c;
  margin-bottom: 30rpx;
}

.claim-actions-flex {
  display: flex;
}

.ml-20 {
  margin-left: 20rpx;
}

/* Sticky Bottom Action Bar */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  border-top: 1rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.05);
}

.action-bar-inner {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  height: 110rpx;
}

.action-icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 90rpx;
  margin-right: 20rpx;
}

.icon-large {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.action-btn-text {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.action-main-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, var(--color-cta) 0%, var(--color-primary) 100%);
  border-radius: 44rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(3, 105, 161, 0.3);
  margin-left: 20rpx;
}
