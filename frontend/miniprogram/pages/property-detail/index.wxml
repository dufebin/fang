<view wx:if="{{property}}" class="page">
  <!-- 图片/视频轮播 -->
  <view class="swiper-wrap">
    <swiper class="img-swiper" circular indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff" bindchange="onSwiperChange">
      <swiper-item wx:for="{{mediaItems}}" wx:key="index">
        <video
          wx:if="{{item.type === 'video'}}"
          class="swiper-video"
          src="{{item.url}}"
          controls
          show-center-play-btn
          object-fit="contain"
          enable-play-gesture
        />
        <image
          wx:else
          class="swiper-img"
          src="{{item.url}}"
          mode="aspectFill"
          lazy-load
          bindtap="onPreviewImage"
          data-index="{{index}}"
        />
      </swiper-item>
    </swiper>
    <view class="img-count">{{swiperCurrent+1}}/{{mediaItems.length}}</view>
    <view class="tag-type">{{property.property_type}}</view>
    <view wx:if="{{property.is_verified}}" class="tag-verified">已核验</view>
  </view>

  <!-- 价格与标题 -->
  <view class="price-block">
    <view class="price-row">
      <text class="price-num">{{priceText}}</text>
      <view wx:if="{{isFav}}" class="fav-btn fav-active" bindtap="onToggleFav">♥</view>
      <view wx:else class="fav-btn" bindtap="onToggleFav">♡</view>
    </view>
    <view class="property-title">{{property.title}}</view>
    <view class="property-meta">
      <text>{{layoutText}}</text>
      <text class="dot">·</text>
      <text>{{areaText}}</text>
      <text class="dot">·</text>
      <text>{{floorText}}</text>
      <text class="dot">·</text>
      <text>{{property.district}}</text>
    </view>
    <!-- 佣金展示 -->
    <view wx:if="{{commissionText}}" class="commission-row">
      <text class="commission-label">佣金</text>
      <text class="commission-val">{{commissionText}}</text>
    </view>
    <view wx:if="{{tags.length}}" class="tag-list">
      <text class="prop-tag" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-title">基本信息</view>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">建筑面积</text>
        <text class="info-val">{{areaText}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">户型</text>
        <text class="info-val">{{layoutText}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">楼层</text>
        <text class="info-val">{{floorText}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">朝向</text>
        <text class="info-val">{{property.orientation || '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">装修</text>
        <text class="info-val">{{property.decoration || '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">电梯</text>
        <text class="info-val">{{property.has_elevator ? '有' : '无'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">车位</text>
        <text class="info-val">{{property.parking != null ? property.parking + '个' : '--'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">楼龄</text>
        <text class="info-val">{{property.building_age != null ? property.building_age + '年' : '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 房源描述 -->
  <view wx:if="{{property.description}}" class="section">
    <view class="section-title">房源描述</view>
    <view class="description-text">{{property.description}}</view>
  </view>

  <!-- 贷款计算入口 -->
  <view class="loan-entry" bindtap="onLoanCalc">
    <text>月供估算</text>
    <text class="loan-val">{{monthlyText}}</text>
    <text class="loan-hint">点击计算 ></text>
  </view>

  <!-- 经纪人信息 -->
  <view class="section">
    <view class="section-title">经纪人</view>
    <agent-card agent="{{agent}}" showActions="{{true}}" />
  </view>

  <!-- 认领房源 -->
  <view class="section">
    <view class="section-title">推广此房源</view>
    <view wx:if="{{isClaimed}}" class="claim-claimed-row">
      <text class="claim-claimed-text">已认领</text>
      <view wx:if="{{myClaimCommission != null}}" class="claim-commission-info">
        <text>我的佣金：{{myClaimCommission}}元</text>
      </view>
      <view class="claim-share-btn" bindtap="onShare">生成分享链接</view>
      <view class="claim-cancel-btn" bindtap="onUnclaim">取消认领</view>
    </view>
    <view wx:else class="claim-row">
      <view class="claim-input-wrap">
        <input class="claim-commission-input" type="digit" placeholder="我的佣金（元，选填）" value="{{claimCommissionInput}}" bindinput="onClaimCommissionInput" />
      </view>
      <view class="claim-btn" bindtap="onClaim">认领并推广</view>
    </view>
  </view>

  <view class="safe-bottom" />
</view>

<view wx:elif="{{!loadingFailed}}" class="loading-page">
  <text>加载中...</text>
</view>

<view wx:else class="loading-page" bindtap="onReload">
  <view class="error-icon">😞</view>
  <text>加载失败，点击重试</text>
</view>
