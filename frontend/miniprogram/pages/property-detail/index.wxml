<view wx:if="{{property}}" class="page pb-safe">
  <!-- 图片/视频轮播 -->
  <view class="swiper-wrap">
    <swiper class="img-swiper" circular indicator-dots="{{false}}" bindchange="onSwiperChange">
      <swiper-item wx:for="{{mediaItems}}" wx:key="index">
        <video
          wx:if="{{item.type === 'video'}}"
          class="swiper-video"
          src="{{item.url}}"
          controls
          show-center-play-btn
          object-fit="cover"
          enable-play-gesture
        />
        <image
          wx:else
          class="swiper-img"
          src="{{item.url}}"
          mode="aspectFill"
          lazy-load
          bindtap="onPreviewImage"
          data-index="{{index}}"
        />
      </swiper-item>
    </swiper>
    
    <!-- 悬浮标记块 -->
    <view class="media-overlay-top">
      <view class="media-tags">
        <view class="tag-glass">{{propertyTypeText}}</view>
        <view wx:if="{{property.is_verified}}" class="tag-glass tag-success">✓ 已核验</view>
      </view>
    </view>
    <view class="media-overlay-bottom">
      <view class="img-count-glass">{{swiperCurrent+1}} / {{mediaItems.length}}</view>
    </view>
  </view>

  <!-- 价格与标题 -->
  <view class="section card-top-radius shadow-sm">
    <view class="price-row">
      <view class="price-col">
        <text class="price-main-huge">{{priceText}}</text>
        <text wx:if="{{unitPriceText !== '--'}}" class="unit-price-sub">约 {{unitPriceText}}</text>
      </view>
      <view class="action-icons">
        <view wx:if="{{isOwner}}" class="action-btn-small" bindtap="onEditProperty">编辑</view>
        <view wx:else class="action-btn-small" bindtap="onToggleFav">
          <text class="{{isFav ? 'text-price' : 'text-gray'}}">{{isFav ? '♥' : '♡'}}</text>
        </view>
      </view>
    </view>
    
    <view class="property-title-lg">{{property.title}}</view>
    
    <view class="property-meta-flex">
      <view class="meta-item">
        <text class="meta-val">{{layoutText}}</text>
        <text class="meta-label">户型</text>
      </view>
      <view class="meta-divider"></view>
      <view class="meta-item">
        <text class="meta-val">{{areaText}}</text>
        <text class="meta-label">面积</text>
      </view>
      <view class="meta-divider"></view>
      <view class="meta-item">
        <text class="meta-val">{{floorText}}</text>
        <text class="meta-label">楼层</text>
      </view>
    </view>
    
    <view class="district-row">
      <view class="loc-dot"></view>
      <text>{{locationText}}</text>
    </view>

    <!-- 佣金展示 -->
    <view wx:if="{{commissionText}}" class="commission-banner">
      <text class="commission-badge">平台佣金</text>
      <text class="commission-amount">{{commissionText}}</text>
    </view>
    
    <view wx:if="{{tags.length}}" class="tag-list mt-20">
      <text class="tag tag-primary" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 房源数据：热度 / 时间 / 状态 + 贷款估算入口 -->
  <view class="stat-section">
    <view class="signal-grid">
      <view class="signal-item">
        <text class="signal-val">{{heatText}}</text>
        <text class="signal-label">浏览热度</text>
      </view>
      <view class="signal-divider"></view>
      <view class="signal-item">
        <text class="signal-val">{{publishAgoText}}</text>
        <text class="signal-label">发布时间</text>
      </view>
      <view class="signal-divider"></view>
      <view class="signal-item">
        <text class="signal-val">{{statusText || '--'}}</text>
        <text class="signal-label">房源状态</text>
      </view>
    </view>
    <view wx:if="{{trustSignals.length}}" class="trust-list">
      <text class="trust-pill" wx:for="{{trustSignals}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="loan-entry hover-scale" bindtap="onLoanCalc">
      <view class="loan-entry-left">
        <view class="loan-entry-icon">月供</view>
        <text class="loan-entry-title">月供估算</text>
      </view>
      <view class="loan-entry-right">
        <text class="loan-entry-val">{{monthlyText}}</text>
        <text class="loan-entry-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{highlightCards.length}}" class="section">
    <view class="section-title-accent">核心卖点</view>
    <view class="highlight-grid">
      <view class="highlight-card" wx:for="{{highlightCards}}" wx:key="label">
        <view class="highlight-label">{{item.label}}</view>
        <view class="highlight-value">{{item.value}}</view>
        <view class="highlight-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{dealInfoList.length}}" class="section">
    <view class="section-title-accent">位置与交易信息</view>
    <view class="deal-info-list">
      <view class="deal-info-item" wx:for="{{dealInfoList}}" wx:key="label">
        <text class="deal-info-label">{{item.label}}</text>
        <text class="deal-info-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-title-accent">基本信息</view>
    <view class="info-grid-clean">
      <view class="info-cell">
        <text class="info-lbl">朝向</text>
        <text class="info-txt">{{property.orientation || '--'}}</text>
      </view>
      <view class="info-cell">
        <text class="info-lbl">装修</text>
        <text class="info-txt">{{property.decoration || '--'}}</text>
      </view>
      <view class="info-cell">
        <text class="info-lbl">电梯</text>
        <text class="info-txt">{{property.has_elevator ? '有' : '无'}}</text>
      </view>
      <view class="info-cell">
        <text class="info-lbl">车位</text>
        <text class="info-txt">{{property.parking != null ? property.parking + '个' : '--'}}</text>
      </view>
      <view class="info-cell">
        <text class="info-lbl">楼龄</text>
        <text class="info-txt">{{property.building_age != null ? property.building_age + '年' : '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 房源描述 -->
  <view wx:if="{{property.description}}" class="section">
    <view class="section-title-accent">房源描述</view>
    <rich-text class="description-rich" nodes="{{property.description}}" />
  </view>

  <!-- 经纪人信息 -->
  <view class="section">
    <view class="section-title-accent">经纪人</view>
    <agent-card agent="{{agent}}" showActions="{{false}}" />
  </view>

  <!-- 认领并推广（自己的房源不显示） -->
  <view wx:if="{{canShowClaimSection}}" class="section claim-section-new">
    <view class="section-title-accent">认领并推广</view>

    <!-- 未认领 -->
    <view wx:if="{{!isClaimed}}" class="claim-box">
      <view class="claim-header">
        <text class="claim-title">成为此房源的推广者</text>
        <text class="claim-subtitle">成交后按约定佣金结算</text>
      </view>
      <view class="claim-input-glass">
        <input
          class="claim-input-field"
          type="digit"
          placeholder="期望佣金 (选填)"
          placeholder-class="claim-ph"
          value="{{claimCommissionInput}}"
          bindinput="onClaimCommissionInput"
        />
        <text class="claim-unit">元</text>
      </view>
      <view class="btn-primary mt-20 hover-scale" bindtap="onClaim">立即认领</view>
    </view>

    <!-- 已认领 -->
    <view wx:else class="claim-box active">
      <view class="claim-status-badge-new">✓ 已认领</view>
      <view wx:if="{{myClaimCommission != null}}" class="claim-commission-text">专属佣金: {{myClaimCommission}} 元</view>
      <view class="claim-actions-flex">
        <view class="btn-primary flex-1 hover-scale" bindtap="onShare">生成推广海报</view>
        <view class="btn-outline flex-1 ml-20 hover-scale" bindtap="onUnclaim">取消认领</view>
      </view>
    </view>
  </view>

  <!-- Bottom Padding for Sticky Bar -->
  <view class="bottom-padding"></view>

  <!-- 悬浮底部操作栏 Sticky Bottom Action Bar -->
  <view class="bottom-action-bar glass">
    <view class="action-bar-inner">
      <view class="action-icon-btn hover-scale" bindtap="onToggleFav">
        <text class="{{isFav ? 'text-price' : 'text-gray'}} icon-large">{{isFav ? '♥' : '♡'}}</text>
        <text class="action-btn-text">收藏</text>
      </view>
      <view class="action-icon-btn hover-scale" bindtap="onShare">
        <text class="text-gray icon-large">⎘</text>
        <text class="action-btn-text">分享</text>
      </view>
      <view class="action-main-btn hover-scale" bindtap="onCallAgent">
        电话联系
      </view>
    </view>
  </view>
</view>

<view wx:elif="{{!loadingFailed}}" class="loading-page">
  <view class="spinner"></view>
  <text class="mt-20">正在获取房源信息...</text>
</view>

<view wx:else class="loading-page" bindtap="onReload">
  <text class="error-emoji">😕</text>
  <text class="mt-20">加载失败，点击重试</text>
</view>
