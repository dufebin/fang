.page { background: #f5f5f5; min-height: 100vh; padding: 24rpx; }

.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-hint { font-size: 24rpx; color: #888; margin-top: 16rpx; }

.form-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 28rpx; }

.form-item { margin-bottom: 28rpx; }

.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }

.form-input {
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #222;
  width: 100%;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.save-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #E84040;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}
