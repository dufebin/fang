.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 24rpx;
}

.appt-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.appt-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.appt-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.appt-time {
  font-size: 26rpx;
  color: #666;
}

.appt-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending  { background: #fff7e6; color: #fa8c16; }
.status-confirmed { background: #f0fff4; color: #52c41a; }
.status-cancelled { background: #f5f5f5; color: #aaa; }
.status-completed { background: #f0f5ff; color: #1890ff; }

.appt-note {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}

.appt-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.action-cancel {
  font-size: 24rpx;
  color: #E84040;
  padding: 8rpx 24rpx;
  border: 1rpx solid #E84040;
  border-radius: 20rpx;
}
