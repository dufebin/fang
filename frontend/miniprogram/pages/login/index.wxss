.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #fff;
  padding: 0 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #E84040;
}

.slogan {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  margin-bottom: 80rpx;
}

.login-btn-wrap {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #E84040;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.login-tip {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 20rpx;
}
