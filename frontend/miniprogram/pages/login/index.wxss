.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #fff;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.slogan {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  margin-bottom: 56rpx;
}

/* 头像选择按钮 */
.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 3rpx solid #e8f0f3;
}

.avatar-hint {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 12rpx;
}

/* 昵称输入 */
.nickname-wrap {
  width: 100%;
  margin-bottom: 48rpx;
  border-bottom: 1.5rpx solid #e8f0f3;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  text-align: center;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.login-tip {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 20rpx;
}
