.page {
  background: var(--color-bg);
  min-height: 100vh;
}

.sticky-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(15, 118, 110, 0.06);
}

.search-row {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f1f5f9;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  height: 72rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.35;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 12rpx;
  color: var(--color-text);
}

.search-clear {
  font-size: 36rpx;
  color: #bbb;
  padding: 0 8rpx;
  line-height: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  height: 72rpx;
  background: rgba(15, 118, 110, 0.08);
  border-radius: 40rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.filter-icon-text {
  font-size: 30rpx;
  color: var(--color-primary);
  line-height: 1;
}

.filter-btn text {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* ── 排序 Tab ─────────────────────────────── */
.sort-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f4f3;
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
}

.sort-active {
  color: var(--color-primary);
  font-weight: 600;
}

.sort-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ── 快捷区域筛选 ─────────────────────────── */
.quick-district-scroll {
  background: #fff;
  border-bottom: 1rpx solid #f0f4f3;
}

.quick-district-row {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  white-space: nowrap;
}

.quick-district-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #555;
  background: #f1f5f9;
  white-space: nowrap;
  flex-shrink: 0;
}

.quick-district-active {
  color: var(--color-primary);
  background: rgba(15, 118, 110, 0.1);
  font-weight: 600;
}

/* ── 已选筛选条件 chips ───────────────────── */
.filter-chip-scroll {
  background: #fff;
  border-bottom: 1rpx solid #f0f4f3;
}

.filter-chip-row {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  gap: 12rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(3, 105, 161, 0.08);
  border: 1rpx solid rgba(3, 105, 161, 0.2);
  flex-shrink: 0;
}

.chip-label {
  font-size: 24rpx;
  color: var(--color-cta);
}

.chip-close {
  font-size: 28rpx;
  color: var(--color-cta);
  opacity: 0.6;
  line-height: 1;
}

/* ── 列表区 ──────────────────────────────── */
.list-vertical {
  display: flex;
  flex-direction: column;
  padding: 20rpx 20rpx 40rpx;
  gap: 20rpx;
}

.loading-tip {
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 48rpx 0;
}

.no-more {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 32rpx 0;
}
