.page {
  background: #fff;
  min-height: 100vh;
}

.article-item {
  display: flex;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.article-thumb {
  width: 200rpx;
  height: 140rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.article-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 28rpx;
  color: #222;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 12rpx;
}

.dot { margin: 0 6rpx; }

.no-more {
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 32rpx 0;
}
