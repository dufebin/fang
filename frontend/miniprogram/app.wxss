/* 全局基础样式 */
page {
  background-color: #F0F9FF;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}


/* 主题色 */
.primary-color { color: #0284C7; }
.primary-bg { background-color: #0284C7; }

/* 文字 */
.text-bold { font-weight: 600; }
.text-gray { color: #999; }
.text-small { font-size: 24rpx; }
.text-large { font-size: 36rpx; }
.text-price { color: #0284C7; font-weight: 700; }

/* Flex */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 20rpx rgba(2,132,199,0.09);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #0284C7 0%, #0369A1 100%);
  color: #fff;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(2,132,199,0.30);
}

.btn-primary::after { border: none; }

.btn-primary:active { opacity: 0.85; }

.btn-outline {
  background: transparent;
  color: #0284C7;
  border: 1.5rpx solid #0284C7;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-outline::after { border: none; }

.btn-outline:active { background: #E0F2FE; }

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-red { background: #E0F2FE; color: #0284C7; }
.tag-blue { background: #e8f4ff; color: #1890ff; }
.tag-green { background: #f0fff4; color: #52c41a; }
.tag-gray { background: #f5f5f5; color: #999; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 30rpx;
}

/* 页面底部安全区 */
.safe-bottom { padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx); }

/* 价格文字 */
.price-main {
  font-size: 44rpx;
  font-weight: 700;
  color: #0284C7;
}

.price-unit {
  font-size: 24rpx;
  color: #0284C7;
  font-weight: 400;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 导航栏标题 */
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

/* 列表项 */
.list-item {
  background: #fff;
  padding: 28rpx 30rpx;
  display: flex;
  align-items: center;
}

.list-item + .list-item {
  border-top: 1rpx solid #f5f5f5;
}

.list-item:active {
  background: #F0F9FF;
}

/* Section 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  padding: 30rpx 30rpx 20rpx;
}

/* Section 标题带左侧蓝色装饰条 */
.section-title-accent {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  padding-left: 20rpx;
  position: relative;
}

.section-title-accent::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: #0284C7;
  border-radius: 3rpx;
}
